@{
    ViewData["Title"] = "Головна";
}

<section class="glass p-4 p-md-5 mb-4 reveal">
    <div class="row align-items-center g-4">
        <div class="col-lg-7">
            <div class="d-inline-flex align-items-center gap-2 mb-3">
                <span class="badge rounded-pill" style="background: color-mix(in srgb, var(--check-green) 20%, transparent); color: var(--text); border: 1px solid var(--border);">
                    Аналіз тендерів
                </span>
                <span class="badge rounded-pill" style="background: color-mix(in srgb, var(--check-red) 13%, transparent); color: var(--text); border: 1px solid var(--border);">
                    Prom.ua + Prozorro
                </span>
            </div>

            <h1 class="h-display display-5 fw-bold mb-3">
                Порівнюй тендерні ціни з ринком
                <span class="d-block" style="color: color-mix(in srgb, var(--check-green) 85%, var(--text));">швидко та аргументовано.</span>
            </h1>
            <p class="fs-5 text-muted-2 mb-4">
                CheckIT — веб‑сервіс для аналізу приватних (Excel) та державних (Prozorro) тендерів
                з порівнянням цін із Prom.ua.
            </p>

            @if (User?.Identity?.IsAuthenticated == true)
            {
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-checkit px-4" asp-controller="ExcelAnalysis" asp-action="Index">Аналіз Excel-тендеру</a>
                    <a class="btn btn-outline-pro px-4" asp-controller="ProzorroAnalysis" asp-action="Index">Аналіз Prozorro</a>
                    @if (User.IsInRole("Admin"))
                    {
                        <a class="btn btn-outline-pro px-4" style="border-color: color-mix(in srgb, var(--check-red) 35%, var(--border));" asp-controller="Admin" asp-action="Users">Адмін‑панель</a>
                    }
                </div>
            }
            else
            {
                <div class="d-flex gap-2 flex-wrap">
                    <a class="btn btn-checkit px-4" asp-controller="Account" asp-action="Login">Увійти</a>
                    <a class="btn btn-outline-pro px-4" asp-controller="Account" asp-action="Register">Зареєструватися</a>
                </div>
                <p class="mt-3 text-muted-2">Для аналізу тендерів потрібно увійти в систему.</p>
            }
        </div>

        <div class="col-lg-5">
            <div class="card-pro p-4 reveal" style="background: linear-gradient(135deg, color-mix(in srgb, var(--card) 85%, transparent), color-mix(in srgb, var(--check-green) 14%, transparent));">
                <div class="d-flex align-items-start justify-content-between">
                    <div>
                        <div class="text-muted-2">Сценарії</div>
                        <div class="fw-semibold">Excel / Prozorro</div>
                    </div>
                    <div class="badge rounded-pill" style="background: color-mix(in srgb, var(--check-green) 22%, transparent); border:1px solid var(--border);">Live</div>
                </div>

                <hr style="border-color: var(--border);" />

                <div class="d-grid gap-2">
                    <div class="d-flex justify-content-between">
                        <span class="text-muted-2">Парсинг</span>
                        <span class="fw-semibold">.xlsx / API</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted-2">Порівняння</span>
                        <span class="fw-semibold">UAH</span>
                    </div>
                    <div class="d-flex justify-content-between">
                        <span class="text-muted-2">Логи</span>
                        <span class="fw-semibold">Admin</span>
                    </div>
                </div>

                <div class="mt-3 text-muted-2" style="font-size: 13px;">
                    Порада: для точності додавай у назву бренд/модель.
                </div>
            </div>
        </div>
    </div>
</section>

<section class="row g-3">
    <div class="col-md-6">
        <div class="card-pro p-4 h-100 reveal">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <h2 class="h5 mb-0">Excel (приватні тендери)</h2>
                <span class="badge rounded-pill" style="background: color-mix(in srgb, var(--check-green) 18%, transparent); border: 1px solid var(--border);">.xlsx</span>
            </div>
            <p class="text-muted-2 mb-0">Завантаж .xlsx файл → парсинг → скрейпінг цін → звіт у таблиці.</p>
        </div>
    </div>
    <div class="col-md-6">
        <div class="card-pro p-4 h-100 reveal">
            <div class="d-flex align-items-center justify-content-between mb-2">
                <h2 class="h5 mb-0">Prozorro (державні тендери)</h2>
                <span class="badge rounded-pill" style="background: color-mix(in srgb, var(--check-red) 12%, transparent); border: 1px solid var(--border);">API</span>
            </div>
            <p class="text-muted-2 mb-0">Введи ID → отримаємо позиції через API Prozorro → порівняємо з ринком.</p>
        </div>
    </div>
</section>
