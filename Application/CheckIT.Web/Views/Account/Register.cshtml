@model CheckIT.Web.ViewModels.RegisterViewModel
@{
    ViewData["Title"] = "Реєстрація";
}

<div class="row justify-content-center">
    <div class="col-md-6">
        <section class="card-pro p-4 p-md-5 reveal">
            <h1 class="h4 mb-2 text-center">Реєстрація</h1>
            <p class="text-muted-2 text-center mb-4" style="font-size: 13px;">Створи акаунт і одразу користуйся сервісом.</p>

            <div asp-validation-summary="All" class="text-danger"></div>

            <form method="post" asp-controller="Account" asp-action="Register">
                @Html.AntiForgeryToken()

                <div class="mb-3">
                    <label class="form-label" asp-for="Name">Ім'я</label>
                    <input class="form-control" asp-for="Name" placeholder="Ваше ім'я" />
                    <span class="text-danger" asp-validation-for="Name"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" asp-for="Email">Email</label>
                    <input class="form-control" asp-for="Email" placeholder="email@example.com" />
                    <span class="text-danger" asp-validation-for="Email"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" asp-for="Password">Пароль</label>
                    <input class="form-control" asp-for="Password" type="password" placeholder="Не менше 8 символів" />
                    <span class="text-danger" asp-validation-for="Password"></span>
                </div>

                <div class="mb-3">
                    <label class="form-label" asp-for="ConfirmPassword">Підтвердження паролю</label>
                    <input class="form-control" asp-for="ConfirmPassword" type="password" placeholder="Повторіть пароль" />
                    <span class="text-danger" asp-validation-for="ConfirmPassword"></span>
                </div>

                <button class="btn btn-checkit w-100" type="submit">Зареєструватися</button>
            </form>

            <p class="mt-3 text-center mb-0">
                Вже є акаунт? <a asp-controller="Account" asp-action="Login" data-transition="left">Увійти</a>
            </p>
        </section>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
