@{
    ViewData["Title"] = "Excel тендер";
}

<div class="d-flex justify-content-center">
    <section class="card-pro p-4 p-md-5 reveal" style="max-width: 920px; width: 100%;">
        <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
            <div>
                <h1 class="h4 mb-1">Аналіз Excel?тендеру</h1>
                <p class="text-muted-2 mb-0">Завантаж .xlsx файл (до 10 MB) ? парсинг ? скрейпінг Prom.ua ? звіт.</p>
            </div>
            <span class="badge rounded-pill" style="background: color-mix(in srgb, var(--check-green) 18%, transparent); border: 1px solid var(--border);">.xlsx</span>
        </div>

        <div class="mt-3" asp-validation-summary="All" class="text-danger"></div>

        <form asp-controller="ExcelAnalysis" asp-action="Upload" method="post" enctype="multipart/form-data" class="mt-3" data-show-overlay>
            @Html.AntiForgeryToken()

            <div class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label class="form-label">Excel файл</label>
                    <input class="form-control" type="file" name="file" accept=".xlsx" required />
                    <div class="form-text text-muted-2">Підтримується тільки формат .xlsx</div>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-checkit w-100" type="submit">Почати аналіз</button>
                </div>
            </div>
        </form>

        <div class="mt-4 d-flex justify-content-center">
            <a class="btn btn-outline-pro" asp-controller="Home" asp-action="Index" data-transition="left">На головну</a>
        </div>
    </section>
</div>
