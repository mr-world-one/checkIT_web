@using Microsoft.AspNetCore.Mvc.Rendering
<!DOCTYPE html>
<html lang="uk">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - CheckIT</title>
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
</head>
<body>
<div class="toast-wrap" data-toast-host></div>

@{
    var c = ViewContext.RouteData.Values["controller"]?.ToString();
    var showMascot = string.Equals(c, "ExcelAnalysis", StringComparison.OrdinalIgnoreCase)
                     || string.Equals(c, "ProzorroAnalysis", StringComparison.OrdinalIgnoreCase);
}

@if (showMascot)
{
    <div class="overlay" data-progress-overlay aria-hidden="true" data-overlay-variant="mascot">
        <div class="overlay-card progress-mascot" role="status" aria-live="polite">
            <div class="d-flex align-items-center justify-content-between gap-3">
                <div class="fw-semibold" data-overlay-title>Аналізуємо…</div>
                <div class="badge rounded-pill" style="background: color-mix(in srgb, var(--check-green) 18%, transparent); border: 1px solid var(--border);" data-overlay-badge>
                    checkIT
                </div>
            </div>

            <div class="pm-scene mt-3" aria-hidden="true" data-overlay-scene="loading">
                <div class="pm-cloud c1"></div>
                <div class="pm-cloud c2"></div>
                <div class="pm-cloud c3"></div>

                <div class="pm-ground"></div>
                <div class="pm-road"></div>

                <div class="pm-item apple" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M13.2 6.3c1.7-2.0 4.0-2.3 5.3-1.8-.2 1.4-1.1 3.0-2.7 4.0-1.5 1.0-3.1 1.1-3.9.9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                        <path d="M12 7.4c3.5 0 6.4 3 6.4 7 0 5.1-3.1 7.6-6.4 7.6S5.6 19.5 5.6 14.4c0-4 2.9-7 6.4-7Z" stroke="currentColor" stroke-width="1.7"/>
                        <path d="M10.2 5.6c.2-1.3 1.0-2.8 2.4-3.6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                        <path d="M9.3 9.2c.7-.5 1.7-.8 2.7-.8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity=".7"/>
                    </svg>
                </div>

                <div class="pm-item bottle" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M10 2h4v3.2c0 .4.2.9.6 1.2l.7.5c.5.4.7.9.7 1.5V19c0 1.7-1.3 3-3 3h-2c-1.7 0-3-1.3-3-3V9.4c0-.6.2-1.1.7-1.5l.7-.5c.4-.3.6-.8.6-1.2V2Z" stroke="currentColor" stroke-width="1.7"/>
                        <path d="M9 12h6" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity=".75"/>
                        <path d="M10 5.2h4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" opacity=".75"/>
                    </svg>
                </div>

                <div class="pm-item box" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4.5 8.2 12 4l7.5 4.2v8.6L12 21l-7.5-4.2V8.2Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                        <path d="M12 4v17" stroke="currentColor" stroke-width="1.4" opacity=".7"/>
                        <path d="M4.5 8.2 12 12.4l7.5-4.2" stroke="currentColor" stroke-width="1.4" opacity=".7" stroke-linejoin="round"/>
                    </svg>
                </div>

                <div class="pm-item tag" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M3.8 12.2 12.2 3.8h6.2v6.2l-8.4 8.4a2.4 2.4 0 0 1-3.5 0l-2.7-2.7a2.4 2.4 0 0 1 0-3.5Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                        <path d="M15.8 8.2h.01" stroke="currentColor" stroke-width="3" stroke-linecap="round"/>
                    </svg>
                </div>

                <div class="pm-item apple" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M13.2 6.3c1.7-2.0 4.0-2.3 5.3-1.8-.2 1.4-1.1 3.0-2.7 4.0-1.5 1.0-3.1 1.1-3.9.9" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                        <path d="M12 7.4c3.5 0 6.4 3 6.4 7 0 5.1-3.1 7.6-6.4 7.6S5.6 19.5 5.6 14.4c0-4 2.9-7 6.4-7Z" stroke="currentColor" stroke-width="1.7"/>
                        <path d="M10.2 5.6c.2-1.3 1.0-2.8 2.4-3.6" stroke="currentColor" stroke-width="1.7" stroke-linecap="round"/>
                        <path d="M9.3 9.2c.7-.5 1.7-.8 2.7-.8" stroke="currentColor" stroke-width="1.4" stroke-linecap="round" opacity=".7"/>
                    </svg>
                </div>

                <div class="pm-item box" aria-hidden="true">
                    <svg viewBox="0 0 24 24" width="18" height="18" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <path d="M4.5 8.2 12 4l7.5 4.2v8.6L12 21l-7.5-4.2V8.2Z" stroke="currentColor" stroke-width="1.7" stroke-linejoin="round"/>
                        <path d="M12 4v17" stroke="currentColor" stroke-width="1.4" opacity=".7"/>
                        <path d="M4.5 8.2 12 12.4l7.5-4.2" stroke="currentColor" stroke-width="1.4" opacity=".7" stroke-linejoin="round"/>
                    </svg>
                </div>

                <div class="pm-cart">
                    <svg width="72" height="68" viewBox="0 0 72 68" fill="none" xmlns="http://www.w3.org/2000/svg">
                        <polygon points="4,8 64,8 56,40 12,40" fill="#f0f4f7" stroke="#7090a4" stroke-width="2.2" stroke-linejoin="round"/>
                        <line x1="20" y1="8"  x2="18.7" y2="40" stroke="#b8ccd8" stroke-width="1.1"/>
                        <line x1="34" y1="8"  x2="34"   y2="40" stroke="#b8ccd8" stroke-width="1.1"/>
                        <line x1="48" y1="8"  x2="49.3" y2="40" stroke="#b8ccd8" stroke-width="1.1"/>
                        <line x1="6.3"  y1="19" x2="61.7" y2="19" stroke="#b8ccd8" stroke-width="1.1"/>
                        <line x1="9.3"  y1="30" x2="58.7" y2="30" stroke="#b8ccd8" stroke-width="1.1"/>
                        <rect x="10" y="40" width="48" height="5" rx="2" fill="#7090a4"/>
                        <rect x="16" y="45" width="36" height="4" rx="1.5" fill="#9ab0be" opacity=".7"/>
                        <line x1="60" y1="8" x2="60" y2="1" stroke="#7090a4" stroke-width="2.4" stroke-linecap="round"/>
                        <rect x="52" y="-1" width="16" height="4" rx="2" fill="#7090a4"/>
                        <line x1="18" y1="49" x2="12" y2="60" stroke="#7090a4" stroke-width="2.2" stroke-linecap="round"/>
                        <line x1="50" y1="49" x2="56" y2="60" stroke="#7090a4" stroke-width="2.2" stroke-linecap="round"/>
                        <circle cx="12" cy="62" r="5" fill="white" stroke="#4a7080" stroke-width="2"/>
                        <circle cx="12" cy="62" r="1.8" fill="#8aaabb"/>
                        <line x1="12" y1="57" x2="12" y2="67" stroke="#9abbc8" stroke-width="1" opacity=".7"/>
                        <line x1="7"  y1="62" x2="17" y2="62" stroke="#9abbc8" stroke-width="1" opacity=".7"/>
                        <circle cx="56" cy="62" r="5" fill="white" stroke="#4a7080" stroke-width="2"/>
                        <circle cx="56" cy="62" r="1.8" fill="#8aaabb"/>
                        <line x1="56" y1="57" x2="56" y2="67" stroke="#9abbc8" stroke-width="1" opacity=".7"/>
                        <line x1="51" y1="62" x2="61" y2="62" stroke="#9abbc8" stroke-width="1" opacity=".7"/>
                    </svg>
                </div>
            </div>

            <div class="mt-3 overlay-bar"><div></div></div>

            <div class="pm-mini mt-2 text-muted-2" style="font-size: 12px;">
                <span class="g">check</span><span class="r">IT</span> шукає ціни…
            </div>
        </div>
    </div>
}

<div class="overlay overlay-simple" data-simple-overlay aria-hidden="true" data-overlay-variant="simple">
    <div class="overlay-card" role="status" aria-live="polite" style="max-width: 520px;">
        <div class="fw-semibold">Завантаження…</div>
        <div class="mt-3 overlay-bar overlay-bar-green"><div></div></div>
    </div>
</div>

<header>
    <nav class="navbar navbar-expand-lg navbar-light">
        <div class="container">
            <a class="navbar-brand fw-bold" asp-controller="Home" asp-action="Index">
                <span class="brand-mark">
                    <span style="color:var(--check-green)">check</span><span style="color:var(--check-red)">IT</span>
                </span>
            </a>

            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#nav" aria-controls="nav" aria-expanded="false" aria-label="Toggle navigation">
                <span class="navbar-toggler-icon"></span>
            </button>

            <div class="collapse navbar-collapse" id="nav">
                <ul class="navbar-nav ms-auto align-items-lg-center gap-lg-1">
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="Index" data-transition="down">Головна</a></li>
                    <li class="nav-item"><a class="nav-link" asp-controller="Home" asp-action="About" data-transition="down">Про нас</a></li>

                    @if (User?.Identity?.IsAuthenticated == true)
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="ExcelAnalysis" asp-action="Index" data-transition="right">Excel тендер</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="ProzorroAnalysis" asp-action="Index" data-transition="right">Prozorro</a></li>

                        @if (User.IsInRole("Admin"))
                        {
                            <li class="nav-item"><a class="nav-link" style="color:var(--check-red)" asp-controller="Admin" asp-action="Users" data-transition="right">Адмін</a></li>
                        }

                        <li class="nav-item">
                            <form method="post" asp-controller="Account" asp-action="Logout" class="d-inline">
                                @Html.AntiForgeryToken()
                                <button type="submit" class="btn btn-link nav-link">Вийти (@User.Identity!.Name)</button>
                            </form>
                        </li>
                    }
                    else
                    {
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Login" data-transition="right">Увійти</a></li>
                        <li class="nav-item"><a class="nav-link" asp-controller="Account" asp-action="Register" data-transition="right">Реєстрація</a></li>
                    }

                    <li class="nav-item ms-lg-2">
                        <button type="button" class="btn btn-outline-pro" data-theme-toggle aria-pressed="false" title="Перемкнути тему">
                            Тема
                        </button>
                    </li>
                </ul>
            </div>
        </div>
    </nav>
</header>

<div class="container mt-4 page" data-page>
    @if (TempData["Success"] is string s && !string.IsNullOrWhiteSpace(s))
    {
        <div class="d-none" data-server-alert data-kind="success">@s</div>
    }
    @if (TempData["Error"] is string e && !string.IsNullOrWhiteSpace(e))
    {
        <div class="d-none" data-server-alert data-kind="error">@e</div>
    }

    <main role="main" class="pb-3">
        @RenderBody()
    </main>
</div>

<footer class="border-top footer text-muted">
    <div class="container py-3">
        &copy; @DateTime.Now.Year - CheckIT
    </div>
</footer>

<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script src="~/js/site.js" asp-append-version="true"></script>
@await RenderSectionAsync("Scripts", required: false)
</body>
</html>
