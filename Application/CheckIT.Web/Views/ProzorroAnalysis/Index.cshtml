@{
    ViewData["Title"] = "Prozorro";
}

<div class="d-flex justify-content-center">
    <section class="card-pro p-4 p-md-5 reveal" style="max-width: 920px; width: 100%;">
        <div class="d-flex align-items-start justify-content-between gap-3 flex-wrap">
            <div>
                <h1 class="h4 mb-1">Аналіз тендеру Prozorro</h1>
                <p class="text-muted-2 mb-0">Введи ID тендеру або контракту ? отримаємо позиції через API ? порівняємо з ринком.</p>
            </div>
            <span class="badge rounded-pill" style="background: color-mix(in srgb, var(--check-red) 12%, transparent); border: 1px solid var(--border);">API</span>
        </div>

        <div class="mt-3" asp-validation-summary="All" class="text-danger"></div>

        <form asp-controller="ProzorroAnalysis" asp-action="Analyze" method="post" class="mt-3" data-show-overlay>
            @Html.AntiForgeryToken()

            <div class="row g-3 align-items-end">
                <div class="col-md-8">
                    <label class="form-label">ID</label>
                    <input class="form-control" type="text" name="tenderId" placeholder="Напр.: UA-2024-... або ID контракту" required />
                    <div class="form-text text-muted-2">Підказка: можна вставити ID з Prozorro напряму.</div>
                </div>
                <div class="col-md-4">
                    <button class="btn btn-checkit w-100" type="submit">Почати аналіз</button>
                </div>
            </div>
        </form>

        <div class="mt-4 d-flex justify-content-center">
            <a class="btn btn-outline-pro" asp-controller="Home" asp-action="Index" data-transition="left">На головну</a>
        </div>
    </section>
</div>
